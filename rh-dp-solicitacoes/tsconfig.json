{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.mts",
    "scripts/**/*.ts",
    "scripts/**/*.mts",
    "prisma/**/*.ts",
    "tests/**/*.ts",
    "tests/**/*.mts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "dist",
    "build",
    "coverage",
    "tmp",
    "temp",
    "logs",
    "log",
    "backups",
    "backup",
    "uploads",
    "public/uploads",
    "public/generated",
    "**/*.log",
    "**/*.zip",
    "**/*.sql",
    "**/*.csv",
    "**/*.xlsx",
    "**/*.pdf",
    "**/*.dump",
    "**/*.bak"
  ]
}
